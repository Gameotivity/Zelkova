{
  "name": "zelkora",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "cd apps/web && npx drizzle-kit generate",
    "db:push": "cd apps/web && npx drizzle-kit push",
    "db:studio": "cd apps/web && npx drizzle-kit studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.4.0"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.0.0"
  }
}
